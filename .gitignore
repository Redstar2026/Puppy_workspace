# =============================================
# .gitignore para puppy_workspace
# =============================================

# Datos pesados / resultados de BigQuery
*.json
result_*.json
all_results.json
bigquery_results/

# Archivos HTML generados (pueden ser muy grandes)
*.html
# Excepcion: presentaciones del equipo
!git-github-equipo.html

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
.env
*.egg-info/
dist/
build/

# Datos sensibles / PII
*.csv
*.xlsx
*.xls
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Debug y archivos temporales
debug_*.py
debug_*.txt
build_out.txt
*.tmp
